{
  "name": "kitchen-mcp",
  "version": "0.1.0",
  "description": "Local-first Kitchen Model Context Protocol server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kitchen-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "migrate": "tsx src/infrastructure/database/migrate.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "kitchen",
    "model-context-protocol",
    "inventory",
    "recipes"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.10.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^11.1.1",
    "zod": "3.25"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.23.1",
    "typescript": "5.7",
    "vitest": "^3.2.7"
  }
}
